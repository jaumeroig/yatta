<UserControl x:Class="Yatta.App.Views.Dialogs.DeleteRecordConfirmationDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Yatta.App.Markup"
             d:DesignHeight="260"
             d:DesignWidth="420"
             mc:Ignorable="d">
    <StackPanel Width="420">
        <ui:SymbolIcon Symbol="Warning24"
                       FontSize="48"
                       Foreground="#F59E0B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

        <TextBlock Text="{local:Localize Dialog_DeleteRecord_Title}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8" />

        <TextBlock Text="{local:Localize Dialog_DeleteRecord_Message}"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,0" />
    </StackPanel>
</UserControl>
