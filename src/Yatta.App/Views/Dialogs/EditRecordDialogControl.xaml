<UserControl x:Class="Yatta.App.Views.Dialogs.EditRecordDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Yatta.App.Markup"
             xmlns:controls="clr-namespace:Yatta.App.Controls"
             d:DesignHeight="640"
             d:DesignWidth="520"
             mc:Ignorable="d">
    <StackPanel Width="520">
        <TextBlock Text="{Binding EditRecordModel.DialogTitle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20" />

        <TextBlock Text="{local:Localize Label_Activity}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,8" />
        <controls:ActivityComboBox ItemsSource="{Binding EditRecordModel.AvailableActivities}"
                                   SelectedValue="{Binding EditRecordModel.SelectedActivityId}"
                                   Margin="0,0,0,16" />

        <TextBlock Text="{local:Localize Label_Date}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,8" />
        <DatePicker SelectedDate="{Binding EditRecordModel.Date}"
                    HorizontalAlignment="Stretch"
                    Height="40"
                    Margin="0,0,0,16" />

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{local:Localize Label_StartTime}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <controls:TimePickerControl TimeText="{Binding EditRecordModel.StartTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Height="40" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{local:Localize Label_EndTime}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <controls:TimePickerControl TimeText="{Binding EditRecordModel.EndTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Height="40" />
            </StackPanel>
        </Grid>

        <TextBlock Text="{local:Localize Label_WorkLocation}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton Content="{local:Localize Location_Office}"
                         IsChecked="{Binding EditRecordModel.IsOffice}"
                         GroupName="EditRecordLocation"
                         Margin="0,0,16,0" />
            <RadioButton Content="{local:Localize Location_Telework}"
                         IsChecked="{Binding EditRecordModel.Telework}"
                         GroupName="EditRecordLocation" />
        </StackPanel>

        <TextBlock Text="{local:Localize Label_Notes}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,8" />
        <ui:TextBox PlaceholderText="{local:Localize Placeholder_RecordNotes}"
                    Text="{Binding EditRecordModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True"
                    MinHeight="80"
                    Margin="0,0,0,16" />

        <Border Background="#FEE2E2"
                BorderBrush="#EF4444"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,0"
                Visibility="{Binding EditRecordModel.ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding EditRecordModel.ValidationError}"
                       Foreground="#DC2626"
                       TextWrapping="Wrap"
                       FontSize="13" />
        </Border>
    </StackPanel>
</UserControl>
