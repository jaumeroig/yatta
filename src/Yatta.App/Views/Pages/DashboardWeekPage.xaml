<Page x:Class="Yatta.App.Views.Pages.DashboardWeekPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Yatta.App.ViewModels"
      xmlns:converters="clr-namespace:Yatta.App.Converters"
      xmlns:local="clr-namespace:Yatta.App.Markup"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      d:DataContext="{d:DesignInstance vm:DashboardWeekViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Loaded="Page_Loaded"
      ScrollViewer.CanContentScroll="False"
      Unloaded="Page_Unloaded">

    <Page.Resources />


    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="42,0,42,42">
        <StackPanel>
            <!-- Header: week navigation -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="22" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                            <Run Text="{local:Localize Dashboard_Week}" />
                            <Run Text=" " />
                            <Run Text="{Binding WeekNumber, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="{Binding WeekRangeDisplay}" FontSize="14" Opacity="0.6" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Command="{Binding PreviousWeekCommand}" Height="32px" Margin="0,0,4,0" />
                    <ui:Button Content="{local:Localize Button_Today}" Command="{Binding ThisWeekCommand}" Height="32px" Margin="0,0,4,0" />
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Command="{Binding NextWeekCommand}" Height="32px" />
                </StackPanel>
            </Grid>

            <!-- Summary cards -->
            <UniformGrid Rows="1" Columns="3" Margin="0,0,0,16">
                <!-- Worked time -->
                <ui:Card Padding="16" Margin="0,0,8,0" VerticalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="{local:Localize Dashboard_WorkedTime}" FontSize="13" Opacity="0.6" />
                        <TextBlock Text="{Binding WorkedTimeDisplay}" FontSize="28" FontWeight="Bold" Margin="0,4,0,0" />
                        <TextBlock FontSize="13" Opacity="0.6" Margin="0,2,0,0">
                            <Run Text="{local:Localize Dashboard_Target}" />
                            <Run Text=": " />
                            <Run Text="{Binding TargetTimeDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </ui:Card>

                <!-- Differential -->
                <ui:Card Padding="16" Margin="4,0,4,0" VerticalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="{local:Localize Dashboard_Differential}" FontSize="13" Opacity="0.6" />
                        <TextBlock Text="{Binding DifferentialDisplay}" FontSize="28" FontWeight="Bold" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDifferentialPositive}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDifferentialPositive}" Value="False">
                                            <Setter Property="Foreground" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ui:Card>

                <!-- Office / Telework -->
                <ui:Card Padding="16" Margin="8,0,0,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <lvc:PieChart Grid.Column="0"
                                      Series="{Binding TeleworkSeries}"
                                      Width="100" Height="100"
                                      InitialRotation="-90"
                                      LegendPosition="Hidden" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="10" Height="10" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="{local:Localize Location_Office}" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding OfficeTimeDisplay}" FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="10" Height="10" Fill="#2196F3" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="{local:Localize Location_Telework}" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TeleworkTimeDisplay}" FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding TeleworkPercentageDisplay}" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </UniformGrid>

            <!-- Daily hours stacked bar chart -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard_DailyHours}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"  />
                    <lvc:CartesianChart
                        Series="{Binding DailyBarSeries}"
                        XAxes="{Binding DailyBarXAxes}"
                        YAxes="{Binding DailyBarYAxes}"
                        Height="220"
                        LegendPosition="Bottom" />
                </StackPanel>
            </ui:Card>

            <!-- Activity breakdown with donut chart -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard_Activities}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <lvc:PieChart Grid.Column="0"
                                      Series="{Binding ActivitySeries}"
                                      Width="160" Height="160"
                                      InitialRotation="-90"
                                      LegendPosition="Hidden"
                                      Margin="0,0,12,0" />

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding ActivityBreakdown}" VerticalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="12" Height="12" Fill="{Binding ColorBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding ActivityName}" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding TotalTime}" FontSize="14" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding Percentage}" FontSize="13" Opacity="0.6" VerticalAlignment="Center" MinWidth="45" TextAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
