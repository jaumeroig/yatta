<Page x:Class="Yatta.App.Views.Pages.DashboardIndexPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:Yatta.App.Markup" xmlns:viewmodels="clr-namespace:Yatta.App.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:DashboardIndexViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="900"
      Loaded="Page_Loaded"
      ScrollViewer.CanContentScroll="False"
      Unloaded="Page_Unloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="42,0,42,42">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Subtitle -->
            <TextBlock Grid.Row="0"
                       Text="{local:Localize Dashboard_IndexSubtitle}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       FontSize="14"
                       Opacity="0.6"
                       Margin="0,0,0,24" />

            <!-- Four large tiles for each period -->
            <UniformGrid Grid.Row="1" Rows="2" Columns="2" Margin="0,0,0,0">

            <!-- Day tile -->

            <ui:CardAction Command="{Binding NavigateToDayCommand}"
                           Margin="0,0,12,12"
                           BorderThickness="0"
                           Padding="32">
                <StackPanel>
                    <ui:SymbolIcon Symbol="CalendarDay24"
                                   FontSize="40"
                                   Margin="0,0,0,16" />
                    <TextBlock Text="{local:Localize Dashboard_Day}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{local:Localize Dashboard_DayDescription}"
                               FontSize="13"
                               Opacity="0.6"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardAction>

            <!-- Week tile -->
            <ui:CardAction Command="{Binding NavigateToWeekCommand}"
                           Margin="12,0,0,12"
                           BorderThickness="0"
                           Padding="32">
                <StackPanel>
                    <ui:SymbolIcon Symbol="CalendarWeekNumbers24"
                                   FontSize="40"
                                   Margin="0,0,0,16" />
                    <TextBlock Text="{local:Localize Dashboard_Week}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{local:Localize Dashboard_WeekDescription}"
                               FontSize="13"
                               Opacity="0.6"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardAction>

            <!-- Month tile -->
            <ui:CardAction Command="{Binding NavigateToMonthCommand}"
                           Margin="0,12,12,0"
                           BorderThickness="0"
                           Padding="32">
                <StackPanel>
                    <ui:SymbolIcon Symbol="CalendarLtr24"
                                   FontSize="40"
                                   Margin="0,0,0,16" />
                    <TextBlock Text="{local:Localize Dashboard_Month}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{local:Localize Dashboard_MonthDescription}"
                               FontSize="13"
                               Opacity="0.6"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardAction>

            <!-- Year tile -->
            <ui:CardAction Command="{Binding NavigateToYearCommand}"
                           Margin="12,12,0,0"
                           BorderThickness="0"
                           Padding="32">
                <StackPanel>
                    <ui:SymbolIcon Symbol="CalendarAgenda24"
                                   FontSize="40"
                                   Margin="0,0,0,16" />
                    <TextBlock Text="{local:Localize Dashboard_Year}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{local:Localize Dashboard_YearDescription}"
                               FontSize="13"
                               Opacity="0.6"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardAction>

            </UniformGrid>
        </Grid>
    </ScrollViewer>
</Page>
