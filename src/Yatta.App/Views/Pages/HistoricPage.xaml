<Page x:Class="Yatta.App.Views.Pages.HistoricPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
xmlns:vm="clr-namespace:Yatta.App.ViewModels"
xmlns:controls="clr-namespace:Yatta.App.Controls"
xmlns:local="clr-namespace:Yatta.App.Markup"
xmlns:behaviors="clr-namespace:Yatta.App.Behaviors"
d:DataContext="{d:DesignInstance vm:HistoricViewModel}"
mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900"
    Title="Registres"
    ScrollViewer.CanContentScroll="False"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <!-- Main Content -->
    <Grid Margin="42,12,22,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,0,20,24" Height="35">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                            PlaceholderText="{local:Localize Filter_SearchByActivityOrNotes}"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            Margin="0,0,0,0">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:TextBox.Icon>
            </ui:TextBox>

            <ComboBox Grid.Column="1"
                      IsEditable="False"
                      Width="200"
                      VerticalAlignment="Stretch"
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding Activities}"
                      SelectedItem="{Binding SelectedActivityFilter}"
                      Margin="12,0,0,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="12"
                                     Height="12"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Fill="{Binding Color, Converter={StaticResource StringToBrushConverter}}" />
                            <TextBlock Text="{Binding Name}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                        <Setter Property="Tag" Value="{local:Localize Filter_AllActivities}" />
                    </Style>
                </ComboBox.Style>
            </ComboBox>

            <DatePicker Grid.Column="2"
                        Width="130"
                        Padding="12"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        Margin="12,0,0,0"
                        SelectedDateFormat="Short"
                        SelectedDate="{Binding SelectedDate}" />

            <!-- Sort Direction Toggle -->
            <ToggleButton Grid.Column="3"
                          IsChecked="{Binding SortAscending}"
                          VerticalAlignment="Stretch"
                          Margin="12,0,0,0"
                          Width="35"
                          ToolTip="{local:Localize Filter_Sort_Tooltip}">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorSecondaryBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SystemFillColorSecondaryBackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ToggleButton.Style>
                <StackPanel Orientation="Horizontal">
                    <!-- Icon changes based on state -->
                    <ui:SymbolIcon Margin="0,0,0,0">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <!-- Default: descending (arrow down) -->
                                <Setter Property="Symbol" Value="ArrowDown24" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortAscending}" Value="True">
                                        <!-- Ascending: arrow up -->
                                        <Setter Property="Symbol" Value="ArrowUp24" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>

                </StackPanel>
            </ToggleButton>
            
            <ui:Button Grid.Column="4"
                       Appearance="Primary"
                       VerticalAlignment="Stretch"
                       Command="{Binding OpenNewRecordDialogCommand}"
                       Margin="48,0,0,0"
                       Padding="16,0"
                       HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" />
                    <TextBlock Text="{local:Localize Button_NewRecord}" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Records List -->
        <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" >

            <StackPanel>
            <ItemsControl ItemsSource="{Binding GroupedRecords}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,20,32">
                            <!-- Day Header (separador amb label de data) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                               Text="{Binding DateDisplay}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                
                                <TextBlock Grid.Column="1"
                                               Text="{Binding TimeAgo}"
                                               FontSize="12"
                                               FontStyle="Italic"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Grid.Column="2"
                                               Text="{Binding TotalWorked}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:Button Grid.Column="3"
                                               Appearance="Transparent"
                                               BorderThickness="0"
                                               Padding="4"
                                               Margin="16,0,0,0"
                                               VerticalAlignment="Center"
                                               ToolTip="{local:Localize Today_ConfigureDay}"
                                               Command="{Binding DataContext.ConfigureDayCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding Date}">
                                    <ui:SymbolIcon Symbol="Settings24" FontSize="14" />
                                </ui:Button>
                            </Grid>

                            <!-- Timeline bar for this day -->
                            <controls:WorkdayTimelineBar
                                Margin="0,0,0,12"
                                BarHeight="20"
                                CornerRadius="4"
                                WorkdayStart="{Binding WorkdayStart}"
                                WorkdayEnd="{Binding WorkdayEnd}"
                                Segments="{Binding TimelineSegments}"
                                 SegmentDoubleClickedCommand="{Binding DataContext.OpenEditRecordFromSegmentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                 EditCommand="{Binding DataContext.OpenEditRecordFromSegmentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                 DeleteCommand="{Binding DataContext.RequestDeleteRecordFromSegmentCommand, RelativeSource={RelativeSource AncestorType=Page}}" />

                            <!-- Records for this day -->
                            <ItemsControl ItemsSource="{Binding Records}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:TimeRecordCard Margin="0,0,0,4"
                                                                 behaviors:ScrollParentBehavior.BubbleScroll="True"
                                                                 ActivityColor="{Binding ActivityColor}"
                                                                 ActivityName="{Binding ActivityName}"
                                                                 IsTelework="{Binding Telework}"
                                                                 StartTime="{Binding StartTime}"
                                                                 EndTime="{Binding EndTime}"
                                                                 Duration="{Binding Duration}"
                                                                 Notes="{Binding Notes}"
                                                                 RecordLink="{Binding RecordLink}"
                                                                 IsActive="{Binding IsActive}"
                                                                 CardClickCommand="{Binding DataContext.OpenEditRecordDialogCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 EditCommand="{Binding DataContext.OpenEditRecordDialogCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 DeleteCommand="{Binding DataContext.RequestDeleteRecordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Load more / pagination -->
            <StackPanel Margin="0,0,20,24"
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasMoreRecords, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:Button Appearance="Secondary"
                           Command="{Binding LoadMoreCommand}"
                           IsEnabled="{Binding IsLoadingMore, Converter={StaticResource BoolInverterConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:ProgressRing Width="16" Height="16" Margin="0,0,8,0" IsIndeterminate="True"
                                         Visibility="{Binding IsLoadingMore, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{local:Localize Button_LoadMore}" />
                    </StackPanel>
                </ui:Button>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding GroupedRecords.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
            <ui:SymbolIcon Symbol="Document24"
                               FontSize="48"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />
            <TextBlock Text="{local:Localize Empty_NoRecords}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4" />
            <TextBlock Text="{local:Localize Empty_CreateFirstRecord}"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
