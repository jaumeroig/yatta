<ui:FluentWindow x:Class="Yatta.App.TrayPanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Yatta.App.Markup"
    xmlns:converters="clr-namespace:Yatta.App.Converters"
    SizeToContent="Height"
    Width="380"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded">

    <ui:FluentWindow.Resources>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16"
                              ShadowDepth="4"
                              Direction="270"
                              Opacity="0.3"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,12,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{local:Localize TrayPanel_Title}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <ui:Button Grid.Column="1"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon WindowNew24}"
                           ToolTip="{local:Localize TrayPanel_ButtonOpenApp}"
                           Click="OnOpenAppClick"
                           Margin="0,0,4,0"
                           Padding="8"
                           Height="32"
                           Width="32" />

                <ui:Button Grid.Column="2"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Dismiss24}"
                           Click="OnCloseClick"
                           Padding="8"
                           Height="32"
                           Width="32" />
            </Grid>

            <Separator Grid.Row="1" Margin="0" />

            <!-- Workday Info Section -->
            <StackPanel Grid.Row="2" Margin="16,12,16,12">
                <!-- Date -->
                <TextBlock Text="{Binding CurrentDate}"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />

                <!-- Info Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Worked Time -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{local:Localize TrayPanel_WorkedLabel}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,12,4" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding WorkedTime}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,4" />

                    <!-- Start Time -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{local:Localize TrayPanel_StartLabel}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,12,4" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding StartTime}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,4" />

                    <!-- Status -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{local:Localize TrayPanel_StatusLabel}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,12,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding WorkdayStatus}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                </Grid>

                <!-- Current Activity Section -->
                <Border Margin="0,12,0,0"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="{local:Localize TrayPanel_CurrentActivityLabel}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />

                        <!-- Active Activity Info -->
                        <Grid Visibility="{Binding HasActiveRecord, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Color Indicator -->
                            <Border Grid.Column="0"
                                    Width="4"
                                    Background="{Binding ActivityColor, Converter={StaticResource StringToBrushConverter}}"
                                    CornerRadius="2"
                                    Margin="0,0,8,0" />

                            <!-- Activity Details -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ActivityName}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Text="{Binding ElapsedTime}"
                                           FontSize="13"
                                           FontFamily="Consolas"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- No Active Activity -->
                        <TextBlock Text="{local:Localize TrayPanel_NoActiveActivity}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontStyle="Italic"
                                   Visibility="{Binding HasActiveRecord, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3" Margin="16,0,16,16">
                <!-- Buttons when activity is active -->
                <Grid Visibility="{Binding HasActiveRecord, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="{local:Localize TrayPanel_ButtonChange}"
                               Icon="{ui:SymbolIcon ArrowSwap24}"
                               Appearance="Primary"
                               Click="OnChangeActivityClick"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,4,0" />

                    <ui:Button Grid.Column="1"
                               Content="{local:Localize TrayPanel_ButtonStop}"
                               Icon="{ui:SymbolIcon RecordStop24}"
                               Click="OnStopActivityClick"
                               HorizontalAlignment="Stretch"
                               Margin="4,0,0,0" />
                </Grid>

                <!-- Button when no activity is active -->
                <ui:Button Content="{local:Localize TrayPanel_ButtonStart}"
                           Icon="{ui:SymbolIcon Play24}"
                           Appearance="Primary"
                           Click="OnStartActivityClick"
                           HorizontalAlignment="Stretch"
                           Visibility="{Binding HasActiveRecord, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}" />
            </StackPanel>
        </Grid>
    </Border>
</ui:FluentWindow>
