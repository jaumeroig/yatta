<UserControl x:Class="Yatta.App.Controls.TimePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Yatta.App.Markup"
             x:Name="Root"
             d:DesignHeight="40"
             d:DesignWidth="200"
             mc:Ignorable="d">
    <ComboBox x:Name="TimeComboBox"
              IsEditable="True"
              AutomationProperties.Name="{local:Localize Placeholder_Time}"
              ItemsSource="{Binding TimeOptions, ElementName=Root}"
              Height="40" />
</UserControl>
