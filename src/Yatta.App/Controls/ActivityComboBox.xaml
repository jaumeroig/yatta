<UserControl x:Class="Yatta.App.Controls.ActivityComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Yatta.App.Markup"
             x:Name="Root"
             d:DesignHeight="40"
             d:DesignWidth="300"
             mc:Ignorable="d">
    <ComboBox ItemsSource="{Binding ItemsSource, ElementName=Root}"
              SelectedValue="{Binding SelectedValue, ElementName=Root}"
              SelectedValuePath="Id"
              Height="40"
              HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12"
                             Height="12"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"
                             Fill="{Binding Color, Converter={StaticResource StringToBrushConverter}}" />
                    <TextBlock Text="{Binding Name}" />
                </StackPanel>
            </DataTemplate>
        </ComboBox.ItemTemplate>
        <ComboBox.Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Tag" Value="{local:Localize Placeholder_SelectActivity}" />
            </Style>
        </ComboBox.Style>
    </ComboBox>
</UserControl>
