<UserControl x:Class="Yatta.App.Controls.TimeRecordCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Yatta.App.Markup"
             x:Name="Root"
             d:DesignHeight="96"
             d:DesignWidth="760"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Storyboard x:Key="ActiveRecordRotationStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0"
                             To="360"
                             Duration="0:0:4" />
        </Storyboard>
    </UserControl.Resources>
    <Border x:Name="ActiveBorder"
            BorderThickness="1"
            CornerRadius="4"
            Padding="0">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, ElementName=Root}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <ui:CardAction Command="{Binding CardClickCommand, ElementName=Root}"
                       CommandParameter="{Binding CommandParameter, ElementName=Root}"
                       IsChevronVisible="False"
                       BorderThickness="0"
                       Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1" Margin="12,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Activity Color Indicator -->
                    <Ellipse Grid.Column="0"
                                         Width="24"
                                         Height="24"
                                         Margin="0,0,16,0"
                                         VerticalAlignment="Center"
                                         Fill="{Binding ActivityColor, Converter={StaticResource StringToBrushConverter}}" />

                    <ui:SymbolIcon Grid.Column="0"
                                   x:Name="LocationIcon"
                                   Symbol="Building24"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   ToolTip="{local:Localize Location_Office}" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActivityName, ElementName=Root}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock x:Name="NotesTextBlock"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Notes, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}" />

                        <ui:Button x:Name="ToggleNotesButton"
                                   Appearance="Transparent"
                                   Padding="2"
                                   Margin="0,2,0,0"
                                   Width="24"
                                   Height="24"
                                   BorderThickness="0"
                                   HorizontalAlignment="Left"
                                   Click="ToggleNotesButton_Click"
                                   Visibility="Collapsed">
                            <ui:SymbolIcon x:Name="ToggleNotesIcon" Symbol="ChevronDown24" FontSize="14" />
                        </ui:Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="0,0,18,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:SymbolIcon Symbol="ArrowClockwise16"
                                           FontSize="16"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           RenderTransformOrigin="0.5,0.5">
                                <ui:SymbolIcon.RenderTransform>
                                    <RotateTransform />
                                </ui:SymbolIcon.RenderTransform>
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive, ElementName=Root}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="ActiveRecordRotationBeginStoryboard" Storyboard="{StaticResource ActiveRecordRotationStoryboard}" />
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="ActiveRecordRotationBeginStoryboard" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>

                            <TextBlock Text="{Binding Duration, ElementName=Root}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding StartTime, ElementName=Root}" />
                            <Run Text=" - " />
                            <Run Text="{Binding EndTime, ElementName=Root}" />
                        </TextBlock>
                    </StackPanel>

                    <ui:Button Grid.Column="3"
                               x:Name="OpenLinkButton"
                               Appearance="Transparent"
                               Padding="4"
                               BorderThickness="0"
                               VerticalAlignment="Center"
                               ToolTip="{Binding RecordLink, ElementName=Root}"
                               Visibility="Collapsed"
                               Click="OpenLinkButton_Click">
                        <ui:SymbolIcon Symbol="Open24" FontSize="16" />
                    </ui:Button>

                    <ui:Button Grid.Column="4"
                               x:Name="RecordMenuButton"
                               Appearance="Transparent"
                               Padding="4"
                               BorderThickness="0"
                               VerticalAlignment="Center"
                               Click="RecordMenuButton_Click">
                        <ui:SymbolIcon Symbol="MoreVertical24" FontSize="16" />
                        <ui:Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{local:Localize Menu_Edit}" Click="EditMenuItem_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Edit24" FontSize="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{local:Localize Menu_Delete}" Click="DeleteMenuItem_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Delete24"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>
                </Grid>
            </Grid>
        </ui:CardAction>
    </Border>
</UserControl>
