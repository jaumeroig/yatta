<Application x:Class="TimeTracker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:TimeTracker.App.Converters"
             xmlns:local="clr-namespace:TimeTracker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Global Converters -->
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <converters:EditingToTitleConverter x:Key="EditingToTitleConverter" />
            <converters:EditingToButtonTextConverter x:Key="EditingToButtonTextConverter" />
            <converters:ActivityEditingToTitleConverter x:Key="ActivityEditingToTitleConverter" />
            <converters:ActivityEditingToButtonTextConverter x:Key="ActivityEditingToButtonTextConverter" />
            <converters:ActivityStatusToBackgroundConverter x:Key="ActivityStatusToBackgroundConverter" />
            <converters:ActivityStatusToForegroundConverter x:Key="ActivityStatusToForegroundConverter" />
            
            <!-- Color Button Style -->
            <Style x:Key="ColorButtonStyle" TargetType="Button">
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorSecondary}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
