<Page x:Class="TimeTracker.App.Views.Pages.DashboardDayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
      xmlns:converters="clr-namespace:TimeTracker.App.Converters"
      xmlns:controls="clr-namespace:TimeTracker.App.Controls"
      xmlns:local="clr-namespace:TimeTracker.App.Markup"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      d:DataContext="{d:DesignInstance vm:DashboardDayViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <converters:DateInMultipleCollectionsToVisibilityConverter x:Key="DateInMultipleCollectionsToVisibilityConverter" />
        <converters:StringToBrushConverter x:Key="StringToBrushConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BarWidthConverter x:Key="BarWidthConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <!-- Calendar day button style with indicators (reused from JornadaPage) -->
        <Style x:Key="CalendarDayButtonStyleWithIndicator" TargetType="CalendarDayButton">
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Background" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Background" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected" />
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Background" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" />
                                            <ColorAnimation Storyboard.TargetName="Background"
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="{DynamicResource SystemAccentColor}" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CalendarButtonFocusStates">
                                    <VisualState x:Name="CalendarButtonUnfocused" />
                                    <VisualState x:Name="CalendarButtonFocused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="ActiveStates">
                                    <VisualState x:Name="Active" />
                                    <VisualState x:Name="Inactive">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Content" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="DayStates">
                                    <VisualState x:Name="RegularDay" />
                                    <VisualState x:Name="Today">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TodayBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Border x:Name="Background" Background="{DynamicResource SystemAccentColorSecondaryBrush}" CornerRadius="20" Opacity="0" />
                            <Border x:Name="TodayBorder" BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}" BorderThickness="2" CornerRadius="20" Visibility="Collapsed" />
                            <Border x:Name="FocusBorder" BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}" BorderThickness="1" CornerRadius="20" Visibility="Collapsed" />
                            <ContentPresenter x:Name="Content" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4" Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#4CAF50" Margin="0,0,2,0">
                                    <Ellipse.Visibility>
                                        <MultiBinding Converter="{StaticResource DateInMultipleCollectionsToVisibilityConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="DataContext" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.OfficeDates" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.BothDates" />
                                        </MultiBinding>
                                    </Ellipse.Visibility>
                                </Ellipse>
                                <Ellipse Width="6" Height="6" Fill="#2196F3" Margin="2,0,0,0">
                                    <Ellipse.Visibility>
                                        <MultiBinding Converter="{StaticResource DateInMultipleCollectionsToVisibilityConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="DataContext" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.TeleworkDates" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.BothDates" />
                                        </MultiBinding>
                                    </Ellipse.Visibility>
                                </Ellipse>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="Opacity" Value="0.2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="42,12,42,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left column: Calendar -->
                <ui:Card Grid.Column="0" Padding="16" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Month navigation -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Column="0" Appearance="Transparent" Command="{Binding PreviousMonthCommand}" Padding="8">
                                <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16" />
                            </ui:Button>
                            <TextBlock Grid.Column="1" Text="{Binding MonthYear}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <ui:Button Grid.Column="2" Appearance="Transparent" Command="{Binding NextMonthCommand}" Padding="8">
                                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="16" />
                            </ui:Button>
                        </Grid>

                        <!-- WPF Calendar -->
                        <Calendar x:Name="DashboardCalendar"
                                  SelectionMode="SingleDate"
                                  DisplayDate="{Binding SelectedDate, Mode=TwoWay}"
                                  SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                  SelectedDatesChanged="Calendar_SelectedDatesChanged"
                                  DisplayDateChanged="Calendar_DisplayDateChanged"
                                  IsTodayHighlighted="True"
                                  FirstDayOfWeek="Monday">
                            <Calendar.CalendarDayButtonStyle>
                                <StaticResource ResourceKey="CalendarDayButtonStyleWithIndicator" />
                            </Calendar.CalendarDayButtonStyle>
                        </Calendar>

                        <!-- Today button -->
                        <ui:Button Content="{local:Localize Button_Today}"
                                   Appearance="Secondary"
                                   Command="{Binding TodayCommand}"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,12,0,0"
                                   Height="40"
                                   Padding="12,0" />
                    </StackPanel>
                </ui:Card>

                <!-- Right column: Day details -->
                <StackPanel Grid.Column="2">
                    <!-- Full date header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding FullDateDisplay}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <ui:Button Grid.Column="1"
                                   Appearance="Transparent"
                                   Padding="4"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   ToolTip="{local:Localize Today_ConfigureDay}"
                                   Command="{Binding ConfigureDayCommand}">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="16" />
                        </ui:Button>
                    </Grid>

                    <!-- Day info cards row -->
                    <UniformGrid Columns="3" Margin="0,0,0,16">
                        <!-- Day type -->
                        <ui:Card Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{local:Localize Today_DayType}"
                                           FontSize="12"
                                           Opacity="0.6"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding DayTypeDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </ui:Card>

                        <!-- Start time -->
                        <ui:Card Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{local:Localize Today_WorkdayStartTime}"
                                           FontSize="12"
                                           Opacity="0.6"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding StartTimeDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </ui:Card>

                        <!-- Target duration -->
                        <ui:Card Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{local:Localize Today_TargetDuration}"
                                           FontSize="12"
                                           Opacity="0.6"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding TargetTimeDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </ui:Card>
                    </UniformGrid>

                    <!-- Worked time and differential -->
                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <ui:Card Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{local:Localize Dashboard_WorkedTime}"
                                           FontSize="12"
                                           Opacity="0.6"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding WorkedTimeDisplay}"
                                           FontSize="24"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{local:Localize Dashboard_Differential}"
                                           FontSize="12"
                                           Opacity="0.6"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding DifferentialDisplay}"
                                           FontSize="24"
                                           FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDifferentialPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="#4CAF50" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDifferentialPositive}" Value="False">
                                                    <Setter Property="Foreground" Value="#F44336" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ui:Card>
                    </UniformGrid>

                    <!-- Office / Telework breakdown -->
                    <ui:Card Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Labels row -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#4CAF50" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{local:Localize Label_OfficeBar}" FontSize="13" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding OfficeTimeDisplay}" FontSize="15" FontWeight="SemiBold" Margin="18,2,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#2196F3" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{local:Localize Label_TeleworkBar}" FontSize="13" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding TeleworkTimeDisplay}" FontSize="15" FontWeight="SemiBold" Margin="18,2,0,0" />
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding TeleworkPercentageDisplay}" FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Bar chart -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Office bar -->
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Height="12"
                                        Margin="0,0,0,4">
                                    <Border Background="#4CAF50"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding OfficeBarWidth, Converter={StaticResource BarWidthConverter}}" />
                                </Border>
                            </Grid>
                            <Grid Grid.Row="2">
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Height="12">
                                    <Border Background="#2196F3"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding TeleworkBarWidth, Converter={StaticResource BarWidthConverter}}" />
                                </Border>
                            </Grid>
                        </Grid>
                    </ui:Card>

                    <!-- Timeline bar -->
                    <ui:Card Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{local:Localize Dashboard_Timeline}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <controls:WorkdayTimelineBar
                                Height="32"
                                Segments="{Binding TimelineSegments}"
                                WorkdayStart="{Binding TimelineStart}"
                                WorkdayEnd="{Binding TimelineEnd}" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Activity breakdown with donut chart -->
                    <ui:Card Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{local:Localize Dashboard_Activities}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Donut chart -->
                                <lvc:PieChart Grid.Column="0"
                                              Series="{Binding ActivitySeries}"
                                              Width="160" Height="160"
                                              InitialRotation="-90"
                                              LegendPosition="Hidden"
                                              Margin="0,0,12,0" />

                                <!-- Activity list -->
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding ActivityBreakdown}" VerticalAlignment="Center">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="0" Width="12" Height="12" Fill="{Binding ColorBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding ActivityName}" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding TotalTime}" FontSize="14" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="{Binding Percentage}" FontSize="13" Opacity="0.6" VerticalAlignment="Center" MinWidth="45" TextAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Records list -->
                    <ui:Card Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{local:Localize Dashboard_Records}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <ItemsControl ItemsSource="{Binding Records}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12" Margin="0,0,0,4"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding ColorBrush}" Margin="0,0,12,0" VerticalAlignment="Center" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ActivityName}" FontSize="14" FontWeight="SemiBold" />
                                                        <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="12" Margin="8,0,0,0"
                                                                       Visibility="{Binding IsTelework, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                       Foreground="#2196F3" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Notes}" FontSize="12" Opacity="0.6"
                                                               Visibility="{Binding Notes, Converter={StaticResource StringToVisibilityConverter}}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right">
                                                        <Run Text="{Binding StartTime, Mode=OneWay}" />
                                                        <Run Text=" - " />
                                                        <Run Text="{Binding EndTime, Mode=OneWay}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Duration}" FontSize="12" Opacity="0.6" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
