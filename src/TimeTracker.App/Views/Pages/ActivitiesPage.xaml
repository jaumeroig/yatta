<Page x:Class="TimeTracker.App.Views.Pages.ActivitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    xmlns:converters="clr-namespace:TimeTracker.App.Converters"
    xmlns:local="clr-namespace:TimeTracker.App.Markup"
    xmlns:behaviors="clr-namespace:TimeTracker.App.Behaviors"
    d:DataContext="{d:DesignInstance vm:ActivitiesViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900"
    Title="Activitats"
    ScrollViewer.CanContentScroll="False"
    Loaded="Page_Loaded">

    <Grid Margin="42,12,22,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Botó de nova activitat y filtres: Cerca per nom i switch per mostrar inactives -->
        <Grid Grid.Row="1" Margin="0,0,20,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Camp de cerca per nom -->
            <ui:TextBox Grid.Column="0"
                        PlaceholderText="{local:Localize Filter_SearchByName}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Icon="{ui:SymbolIcon Search24}" />

            <!-- Switch per mostrar activitats inactives -->
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                <TextBlock Text="{local:Localize Filter_ShowInactive}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,12,0" />
                <ui:ToggleSwitch IsChecked="{Binding ShowInactive}" />
            </StackPanel>

            <ui:Button Grid.Column="2"
                       Appearance="Primary"
                       Command="{Binding NavigateToNewActivityCommand}"
                       Margin="32,0,0,0"
                       Padding="16,6"
                       HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" />
                    <TextBlock Text="{local:Localize Button_NewActivity}" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Activities List (Windows Settings Style) -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding Activities.Count, Converter={StaticResource InverseCountToVisibilityConverter}, FallbackValue=Visible}">
            <ItemsControl ItemsSource="{Binding Activities}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardAction Command="{Binding DataContext.NavigateToActivityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}"
                                       behaviors:ScrollParentBehavior.BubbleScroll="True"
                                       Margin="0,0,20,4"
                                       Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Activity Icon -->
                                <Border Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        CornerRadius="8"
                                        Margin="0,0,16,0"
                                        Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}">
                                    <ui:SymbolIcon Symbol="Grid24"
                                                   Foreground="White"
                                                   FontSize="18" />
                                </Border>

                                <!-- Activity Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <!-- Indicador d'activitat inactiva -->
                                        <Border Visibility="{Binding Active, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{local:Localize Status_Inactive}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Activities.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
            <ui:SymbolIcon Symbol="Grid24"
                           FontSize="48"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,16" />
            <TextBlock Text="{local:Localize Empty_NoActivities}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock Text="{local:Localize Empty_CreateFirstActivity}"
                       FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
