<Page x:Class="TimeTracker.App.Views.Pages.DashboardMonthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
      xmlns:converters="clr-namespace:TimeTracker.App.Converters"
      xmlns:local="clr-namespace:TimeTracker.App.Markup"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      d:DataContext="{d:DesignInstance vm:DashboardMonthViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1100"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <converters:BarWidthConverter x:Key="BarWidthConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="42,0,42,42">
        <StackPanel>
            <!-- Header: month navigation -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="{Binding MonthYearDisplay}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Command="{Binding PreviousMonthCommand}" Height="32px" Margin="0,0,4,0" />
                    <ui:Button Content="{local:Localize Button_Today}" Command="{Binding ThisMonthCommand}" Height="32px" Margin="0,0,4,0" />
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Command="{Binding NextMonthCommand}" Height="32px" />
                </StackPanel>
            </Grid>

            <!-- Summary cards row -->
            <UniformGrid Rows="1" Columns="3" Margin="0,0,0,16">
                <!-- Worked time -->
                <ui:Card Padding="16" Margin="0,0,8,0" VerticalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="{local:Localize Dashboard_WorkedTime}" FontSize="13" Opacity="0.6" />
                        <TextBlock Text="{Binding WorkedTimeDisplay}" FontSize="28" FontWeight="Bold" Margin="0,4,0,0" />
                        <TextBlock FontSize="13" Opacity="0.6" Margin="0,2,0,0">
                            <Run Text="{local:Localize Dashboard_Target}" />
                            <Run Text=": " />
                            <Run Text="{Binding TargetTimeDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </ui:Card>

                <!-- Differential -->
                <ui:Card Padding="16" Margin="4,0,4,0" VerticalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="{local:Localize Dashboard_Differential}" FontSize="13" Opacity="0.6" />
                        <TextBlock Text="{Binding DifferentialDisplay}" FontSize="28" FontWeight="Bold" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDifferentialPositive}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDifferentialPositive}" Value="False">
                                            <Setter Property="Foreground" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ui:Card>

                <!-- Day type counts -->
                <ui:Card Padding="16" Margin="8,0,0,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                            <TextBlock Text="{local:Localize Today_DayType_WorkDay}" FontSize="12" Opacity="0.6" />
                            <TextBlock Text="{Binding WorkDayCount}" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                            <TextBlock Text="{local:Localize Today_DayType_Holiday}" FontSize="12" Opacity="0.6" />
                            <TextBlock Text="{Binding HolidayCount}" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="{local:Localize Today_DayType_Vacation}" FontSize="12" Opacity="0.6" />
                            <TextBlock Text="{Binding VacationCount}" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="{local:Localize Today_DayType_FreeChoice}" FontSize="12" Opacity="0.6" />
                            <TextBlock Text="{Binding FreeChoiceCount}" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </UniformGrid>

            <!-- Office / Telework bar -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{local:Localize Label_OfficeBar}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding OfficeTimeDisplay}" FontSize="15" FontWeight="SemiBold" Margin="18,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#2196F3" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{local:Localize Label_TeleworkBar}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding TeleworkTimeDisplay}" FontSize="15" FontWeight="SemiBold" Margin="18,2,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding TeleworkPercentageDisplay}" FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                </Grid>
            </ui:Card>

            <!-- Daily hours bar chart -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard_DailyHours}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <lvc:CartesianChart
                        Series="{Binding DailyBarSeries}"
                        XAxes="{Binding DailyBarXAxes}"
                        YAxes="{Binding DailyBarYAxes}"
                        Height="250"
                        LegendPosition="Bottom" />
                </StackPanel>
            </ui:Card>

            <!-- Activity donut + list -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard_Activities}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <lvc:PieChart Grid.Column="0"
                                      Series="{Binding ActivitySeries}"
                                      Width="160" Height="160"
                                      InitialRotation="-90"
                                      LegendPosition="Hidden"
                                      Margin="0,0,12,0" />

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding ActivityBreakdown}" VerticalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="12" Height="12" Fill="{Binding ColorBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding ActivityName}" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding TotalTime}" FontSize="14" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding Percentage}" FontSize="13" Opacity="0.6" VerticalAlignment="Center" MinWidth="45" TextAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
