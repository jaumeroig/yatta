<Page x:Class="TimeTracker.App.Views.Pages.TodayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:TimeTracker.App.Controls"
      xmlns:local="clr-namespace:TimeTracker.App.Markup"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="900"
      Loaded="Page_Loaded"
      ScrollViewer.CanContentScroll="False"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <!-- Configure Day Dialog Template -->
        <DataTemplate x:Key="ConfigureDayDialogTemplate">
            <StackPanel Width="480">
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="{local:Localize Dialog_ConfigureDay_Title}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <ui:Button HorizontalAlignment="Right"
                               Appearance="Transparent"
                               Command="{Binding CloseConfigureDayDialogCommand}"
                               Padding="4">
                        <ui:SymbolIcon Symbol="Dismiss24" />
                    </ui:Button>
                </Grid>

                <TextBlock Text="{local:Localize Label_DayType}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <StackPanel Margin="0,0,0,16">
                    <RadioButton Content="{local:Localize Today_DayType_WorkDay}"
                                 IsChecked="{Binding ConfigureDayModel.IsWorkDay}"
                                 GroupName="DayType"
                                 Margin="0,0,0,8" />
                    <RadioButton Content="{local:Localize Today_DayType_IntensiveDay}"
                                 IsChecked="{Binding ConfigureDayModel.IsIntensiveDay}"
                                 GroupName="DayType"
                                 Margin="0,0,0,8" />
                    <RadioButton Content="{local:Localize Today_DayType_Holiday}"
                                 IsChecked="{Binding ConfigureDayModel.IsHoliday}"
                                 GroupName="DayType"
                                 Margin="0,0,0,8" />
                    <RadioButton Content="{local:Localize Today_DayType_FreeChoice}"
                                 IsChecked="{Binding ConfigureDayModel.IsFreeChoice}"
                                 GroupName="DayType"
                                 Margin="0,0,0,8" />
                    <RadioButton Content="{local:Localize Today_DayType_Vacation}"
                                 IsChecked="{Binding ConfigureDayModel.IsVacation}"
                                 GroupName="DayType" />
                </StackPanel>

                <!-- Target Duration (only for working days) -->
                <StackPanel Margin="0,0,0,16"
                            Visibility="{Binding ConfigureDayModel.IsWorkingDayType, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{local:Localize Label_TargetDuration}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ui:TextBox PlaceholderText="{local:Localize Placeholder_TargetDuration}"
                                Text="{Binding ConfigureDayModel.TargetDurationHours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Height="40" />
                </StackPanel>

                <!-- Validation error message -->
                <Border Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,16"
                        Visibility="{Binding ConfigureDayModel.ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ConfigureDayModel.ValidationError}"
                               Foreground="White"
                               TextWrapping="Wrap"
                               FontSize="13" />
                </Border>

                <ui:Button Content="{local:Localize Button_SaveChanges}"
                           Appearance="Primary"
                           HorizontalAlignment="Stretch"
                           Command="{Binding SaveConfigureDayCommand}"
                           Height="40"
                           Padding="16,0" />
            </StackPanel>
        </DataTemplate>

        <!-- Change/Start Activity Dialog Template -->
        <DataTemplate x:Key="ChangeActivityDialogTemplate">
            <StackPanel Width="480">
                <!-- Dialog header with title and close button -->
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="{Binding ChangeActivityModel.DialogTitle}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <ui:Button HorizontalAlignment="Right"
                               Appearance="Transparent"
                               Command="{Binding CloseChangeActivityDialogCommand}"
                               Padding="4">
                        <ui:SymbolIcon Symbol="Dismiss24" />
                    </ui:Button>
                </Grid>

                <!-- Activity dropdown -->
                <TextBlock Text="{local:Localize Label_Activity}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ComboBox ItemsSource="{Binding ChangeActivityModel.AvailableActivities}"
                          SelectedValue="{Binding ChangeActivityModel.SelectedActivityId, Mode=TwoWay}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,0,16"
                          Height="40" />

                <!-- Start date and time -->
                <TextBlock Text="{local:Localize Label_StartDateTime}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0"
                                SelectedDate="{Binding ChangeActivityModel.StartDate, Mode=TwoWay}"
                                Height="40" />
                    <ui:TextBox Grid.Column="2"
                                PlaceholderText="{local:Localize Placeholder_Time}"
                                Text="{Binding ChangeActivityModel.StartTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Height="40" />
                </Grid>

                <!-- Work location -->
                <TextBlock Text="{local:Localize Label_WorkLocation}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="{local:Localize RadioButton_Office}"
                                 IsChecked="{Binding ChangeActivityModel.IsOffice}"
                                 GroupName="ChangeActivityLocation"
                                 Margin="0,0,16,0" />
                    <RadioButton Content="{local:Localize RadioButton_Telework}"
                                 IsChecked="{Binding ChangeActivityModel.Telework}"
                                 GroupName="ChangeActivityLocation" />
                </StackPanel>

                <!-- Notes -->
                <TextBlock Text="{local:Localize Label_Notes}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ui:TextBox PlaceholderText="{local:Localize Placeholder_RecordNotes}"
                            Text="{Binding ChangeActivityModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            AcceptsReturn="True"
                            MinHeight="60"
                            Margin="0,0,0,16" />

                <!-- Validation error -->
                <Border Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,16"
                        Visibility="{Binding ChangeActivityModel.ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ChangeActivityModel.ValidationError}"
                               Foreground="White"
                               TextWrapping="Wrap"
                               FontSize="13" />
                </Border>

                <!-- Primary action button -->
                <ui:Button Content="{Binding ChangeActivityModel.PrimaryButtonText}"
                           Appearance="Primary"
                           HorizontalAlignment="Stretch"
                           Command="{Binding SaveChangeActivityCommand}"
                           IsEnabled="{Binding ChangeActivityModel.HasChanges}"
                           Height="40"
                           Padding="16,0" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="42,0,42,42" MaxWidth="800">

            <!-- === SECTION A: Header row (date + time + day type + configure) === -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Date -->
                <TextBlock Grid.Column="0"
                           Text="{Binding CurrentDate}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Clock -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentTime}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <!-- Day type badge + configure button -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ui:Badge Content="{Binding DayTypeDisplay}"
                              Appearance="Secondary"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <ui:Button Appearance="Transparent"
                               Command="{Binding ConfigureDayCommand}"
                               Padding="6"
                               ToolTip="{local:Localize Today_ConfigureDay}">
                        <ui:SymbolIcon Symbol="Settings24"/>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!-- === SECTION B: Status card (timeline + active record/play + stats) === -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,20">
                <StackPanel>

                    <!-- Stats row: Worked / Target / Remaining / End Time -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Worked -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Today_WorkedTime}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding WorkedTime}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Target (working days only) -->
                        <StackPanel Grid.Column="1"
                                    Visibility="{Binding IsWorkingDay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{local:Localize Today_TargetDuration}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TargetDuration}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Remaining (working days only) -->
                        <StackPanel Grid.Column="2"
                                    Visibility="{Binding IsWorkingDay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{local:Localize Today_RemainingTime}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding RemainingTime}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Estimated end time (working days only) -->
                        <StackPanel Grid.Column="3"
                                    Visibility="{Binding IsWorkingDay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{local:Localize Today_EstimatedEndTime}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding EstimatedEndTime}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Timeline bar (drag segment edges to resize) -->
                    <controls:WorkdayTimelineBar Segments="{Binding TimelineSegments}"
                                                 WorkdayStart="{Binding WorkdayStart}"
                                                 WorkdayEnd="{Binding WorkdayEnd}"
                                                 SegmentResizedCommand="{Binding SegmentResizedCommand}"
                                                 BarHeight="28"
                                                 CornerRadius="6"
                                                 Margin="0,0,0,16"/>


                    <!-- Active Record (when tracking) -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Visibility="{Binding HasActiveRecord, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Activity color + name -->
                            <Ellipse Grid.Column="0"
                                     Width="16"
                                     Height="16"
                                     Fill="{Binding ActiveRecord.ActivityColorBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ActiveRecord.ActivityName}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <ui:Badge Content="{local:Localize Today_InProgress}"
                                              Appearance="Primary"
                                              Padding="4,2"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ActiveRecord.Notes}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding ActiveRecord.Notes, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </StackPanel>

                            <!-- Elapsed time -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ElapsedTime}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,16,0"/>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <ui:Button Appearance="Secondary"
                                           Padding="8"
                                           Margin="0,0,4,0"
                                           ToolTip="{local:Localize Button_Change}"
                                           Command="{Binding ChangeActivityCommand}">
                                    <ui:SymbolIcon Symbol="ArrowSwap24"/>
                                </ui:Button>
                                <ui:Button Appearance="Primary"
                                           Padding="8"
                                           ToolTip="{local:Localize Button_Stop}"
                                           Command="{Binding StopRecordCommand}">
                                    <ui:SymbolIcon Symbol="Stop24"/>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Play Button (when stopped but has records) -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="6"
                            Padding="16"
                            Visibility="{Binding CanPlay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{local:Localize Today_StartTracking}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ui:Button Grid.Column="1"
                                       Appearance="Primary"
                                       Command="{Binding PlayRecordCommand}"
                                       Height="35"
                                       Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Play24" Margin="0,0,6,0"/>
                                    <TextBlock Text="{local:Localize Button_Play}"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- === SECTION C: Completed Records === -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="{local:Localize Today_Records}"
                               FontSize="16"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <!-- No Records Message -->
                    <TextBlock Text="{local:Localize Today_NoRecords}"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,24,0,24"
                               Visibility="{Binding CompletedRecords.Count, Converter={StaticResource CountToVisibilityConverter}}"/>

                    <!-- Records List -->
                    <ItemsControl ItemsSource="{Binding CompletedRecords}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="12"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Activity Color -->
                                        <Border Grid.Column="0"
                                                Width="4"
                                                Background="{Binding ActivityColorBrush}"
                                                CornerRadius="2"
                                                Margin="0,0,12,0"/>

                                        <!-- Record Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ActivityName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                <Run Text="{Binding StartTime}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding EndTime}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Notes}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,1,0,0"
                                                       Visibility="{Binding Notes, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Duration}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
