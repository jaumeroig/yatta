<Page x:Class="TimeTracker.App.Views.Pages.JornadaPage"
x:Name="WorkdayPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
xmlns:converters="clr-namespace:TimeTracker.App.Converters"
xmlns:controls="clr-namespace:TimeTracker.App.Controls"
xmlns:local="clr-namespace:TimeTracker.App.Markup"
xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
d:DataContext="{d:DesignInstance vm:JornadaViewModel}"
mc:Ignorable="d"
    d:DesignHeight="700" d:DesignWidth="1100"
    Title="Jornada"
    ScrollViewer.CanContentScroll="False"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <!-- Estil personalitzat per als dies del calendari amb indicadors -->
        <Style x:Key="CalendarDayButtonStyleWithIndicator" TargetType="CalendarDayButton">
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Background" 
                                                           Storyboard.TargetProperty="Opacity" 
                                                           To="0.6" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Background" 
                                                           Storyboard.TargetProperty="Opacity" 
                                                           To="0.8" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected" />
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Background" 
                                                           Storyboard.TargetProperty="Opacity" 
                                                           To="1" Duration="0:0:0.1" />
                                            <ColorAnimation Storyboard.TargetName="Background"
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="{DynamicResource SystemAccentColor}" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CalendarButtonFocusStates">
                                    <VisualState x:Name="CalendarButtonUnfocused" />
                                    <VisualState x:Name="CalendarButtonFocused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder"
                                                                          Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="ActiveStates">
                                    <VisualState x:Name="Active" />
                                    <VisualState x:Name="Inactive">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Content"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.4" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="DayStates">
                                    <VisualState x:Name="RegularDay" />
                                    <VisualState x:Name="Today">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TodayBorder"
                                                                          Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            
                            <Border x:Name="Background" 
                                    Background="{DynamicResource SystemAccentColorSecondaryBrush}" 
                                    CornerRadius="20" 
                                    Opacity="0" />
                            <Border x:Name="TodayBorder" 
                                    BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}" 
                                    BorderThickness="2" 
                                    CornerRadius="20" 
                                    Visibility="Collapsed" />
                            <Border x:Name="FocusBorder"
                                    BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Visibility="Collapsed" />
                            <ContentPresenter x:Name="Content"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                            <!-- Indicator dots: show both green and blue when work done in both locations -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4" Orientation="Horizontal">
                                <!-- Office (green) - show for Office or Both -->
                                <Ellipse Width="6" Height="6" Fill="#4CAF50" Margin="0,0,2,0">
                                    <Ellipse.Visibility>
                                        <MultiBinding Converter="{StaticResource DateInMultipleCollectionsToVisibilityConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="DataContext" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.OfficeDates" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.BothDates" />
                                        </MultiBinding>
                                    </Ellipse.Visibility>
                                </Ellipse>
                                <!-- Telework (blue) - show for Telework or Both -->
                                <Ellipse Width="6" Height="6" Fill="#2196F3" Margin="2,0,0,0">
                                    <Ellipse.Visibility>
                                        <MultiBinding Converter="{StaticResource DateInMultipleCollectionsToVisibilityConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="DataContext" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.TeleworkDates" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Calendar}" Path="DataContext.BothDates" />
                                        </MultiBinding>
                                    </Ellipse.Visibility>
                                </Ellipse>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="Opacity" Value="0.2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Contingut principal -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="42,12,42,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Contingut principal amb dues columnes -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Columna esquerra: Calendari -->
                    <ui:Card Grid.Column="0" Padding="16" VerticalAlignment="Top">
                        <StackPanel>
                            <!-- Navegació de mes -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:Button Grid.Column="0"
                                           Appearance="Transparent"
                                           Command="{Binding PreviousMonthCommand}"
                                           Padding="8">
                                    <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16" />
                                </ui:Button>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding MonthYear}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />

                                <ui:Button Grid.Column="2"
                                           Appearance="Transparent"
                                           Command="{Binding NextMonthCommand}"
                                           Padding="8">
                                    <ui:SymbolIcon Symbol="ChevronRight24" FontSize="16" />
                                </ui:Button>
                            </Grid>

                            <!-- Calendari WPF -->
                            <Calendar x:Name="WorkdayCalendar"
                                      SelectionMode="SingleDate"
                                      DisplayDate="{Binding SelectedDate, Mode=TwoWay}"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                      SelectedDatesChanged="Calendar_SelectedDatesChanged"
                                      DisplayDateChanged="Calendar_DisplayDateChanged"
                                      IsTodayHighlighted="True"
                                      FirstDayOfWeek="Monday">
                                <Calendar.CalendarDayButtonStyle>
                                    <StaticResource ResourceKey="CalendarDayButtonStyleWithIndicator" />
                                </Calendar.CalendarDayButtonStyle>
                            </Calendar>

                            <!-- Botó per anar a avui -->
                            <ui:Button Content="{local:Localize Button_Today}"
                                       Appearance="Secondary"
                                       Command="{Binding TodayCommand}"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,12,0,0"
                                       Height="40"
                                       Padding="12,0" />

                            <!-- Resum mensual -->
                            <Border Margin="0,16,0,0"
                                    Padding="12"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{local:Localize Section_MonthlySummary}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,12" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{local:Localize Label_TotalWorked}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MonthTotalTime}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{local:Localize Label_TeleworkPercentage}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MonthTeleworkPercentage}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ui:Card>

                    <!-- Columna dreta: Informació del dia seleccionat -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Informació del dia seleccionat -->
                        <ui:Card Grid.Row="0" Padding="20" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Títol del dia -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding SelectedDateDisplay}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,16" />

                                <!-- Estadístiques del dia -->
                                <Grid Grid.Row="1" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="{local:Localize Stat_Total}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TotalWorkedTime}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{local:Localize Stat_Office}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding OfficeTime}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{local:Localize Label_TeleworkBar}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TeleworkTime}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="{local:Localize Label_TeleworkPercentage}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TeleworkPercentage}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <!-- Telework donut chart -->
                                <lvc:PieChart Grid.Row="2"
                                              Series="{Binding TeleworkSeries}"
                                              Width="120" Height="120"
                                              InitialRotation="-90"
                                              LegendPosition="Hidden"
                                              HorizontalAlignment="Center"
                                              Margin="0,8,0,0" />
                            </Grid>
                        </ui:Card>

                        <!-- Timeline bar visual -->
                        <controls:WorkdayTimelineBar
                            Grid.Row="1"
                            Margin="0,0,0,16"
                            BarHeight="24"
                            CornerRadius="6"
                            WorkdayStart="{Binding TimelineStart}"
                            WorkdayEnd="{Binding TimelineEnd}"
                            Segments="{Binding TimelineSegments}" />

                        <!-- Títol de la llista de registres -->
                        <TextBlock Grid.Row="2"
                                   Text="{local:Localize Section_TimeSlots}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,12" />

                        <!-- Llista de registres (només lectura) -->
                        <Grid Grid.Row="3">
                            <!-- Llista de registres quan n'hi ha -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:Card Margin="0,0,0,12" Padding="16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icona -->
                                                    <Border Grid.Column="0"
                                                            Width="44"
                                                            Height="44"
                                                            CornerRadius="8"
                                                            Margin="0,0,12,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <!-- Default: telework (blue) -->
                                                                <Setter Property="Background" Value="#2196F3" />
                                                                <Style.Triggers>
                                                                    <!-- Office: green -->
                                                                    <DataTrigger Binding="{Binding Telework}" Value="False">
                                                                        <Setter Property="Background" Value="#4CAF50" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <ui:SymbolIcon Symbol="{Binding LocationIcon}"
                                                                       FontSize="22"
                                                                       Foreground="White" />
                                                    </Border>

                                                    <!-- Informació del registre -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding LocationText}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15"
                                                                   Margin="0,0,0,2" />
                                                    </StackPanel>

                                                    <!-- Durada -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Duration}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,0,0" />
                                                </Grid>
                                            </ui:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Estat buit -->
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding Slots.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
                                <ui:SymbolIcon Symbol="CalendarLtr24"
                                               FontSize="48"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,16" />
                                <TextBlock Text="{local:Localize Empty_NoSlots}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{local:Localize Empty_AddFirstSlot}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
