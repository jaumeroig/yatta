<Page x:Class="TimeTracker.App.Views.Pages.HistoricPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
xmlns:controls="clr-namespace:TimeTracker.App.Controls"
xmlns:local="clr-namespace:TimeTracker.App.Markup"
xmlns:behaviors="clr-namespace:TimeTracker.App.Behaviors"
d:DataContext="{d:DesignInstance vm:HistoricViewModel}"
mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900"
    Title="Registres"
    ScrollViewer.CanContentScroll="False"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <!-- Edit/Create Record Dialog Template -->
        <DataTemplate x:Key="EditRecordDialogTemplate">
            <StackPanel Width="520">
                <!-- Dialog header with title and close button -->
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="{Binding EditRecordModel.DialogTitle}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <ui:Button HorizontalAlignment="Right"
                               Appearance="Transparent"
                               Command="{Binding CloseEditRecordDialogCommand}"
                               Padding="4">
                        <ui:SymbolIcon Symbol="Dismiss24" />
                    </ui:Button>
                </Grid>

                <!-- Activity -->
                <TextBlock Text="{local:Localize Label_Activity}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <ComboBox ItemsSource="{Binding EditRecordModel.AvailableActivities}"
                          SelectedValue="{Binding EditRecordModel.SelectedActivityId}"
                          SelectedValuePath="Id"
                          Margin="0,0,0,16"
                          Height="40"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="12"
                                         Height="12"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         Fill="{Binding Color, Converter={StaticResource StringToBrushConverter}}" />
                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="Tag" Value="{local:Localize Placeholder_SelectActivity}" />
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <!-- Date -->
                <TextBlock Text="{local:Localize Label_Date}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <DatePicker SelectedDate="{Binding EditRecordModel.Date}"
                            HorizontalAlignment="Stretch"
                            Height="40"
                            Margin="0,0,0,16" />

                <!-- Time fields (start and end) -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{local:Localize Label_StartTime}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8" />
                        <ui:TextBox PlaceholderText="HH:mm"
                                    Text="{Binding EditRecordModel.StartTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{local:Localize Label_EndTime}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8" />
                        <ui:TextBox PlaceholderText="HH:mm"
                                    Text="{Binding EditRecordModel.EndTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" />
                    </StackPanel>
                </Grid>

                <!-- Work location -->
                <TextBlock Text="{local:Localize Label_WorkLocation}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="{local:Localize RadioButton_Office}"
                                 IsChecked="{Binding EditRecordModel.IsOffice}"
                                 GroupName="EditRecordLocation"
                                 Margin="0,0,16,0" />
                    <RadioButton Content="{local:Localize RadioButton_Telework}"
                                 IsChecked="{Binding EditRecordModel.Telework}"
                                 GroupName="EditRecordLocation" />
                </StackPanel>

                <!-- Notes -->
                <TextBlock Text="{local:Localize Label_Notes}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <ui:TextBox PlaceholderText="{local:Localize Placeholder_RecordNotes}"
                            Text="{Binding EditRecordModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            AcceptsReturn="True"
                            MinHeight="80"
                            Margin="0,0,0,16" />

                <!-- Validation error -->
                <Border Background="#FEE2E2"
                        BorderBrush="#EF4444"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,16"
                        Visibility="{Binding EditRecordModel.ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding EditRecordModel.ValidationError}"
                               Foreground="#DC2626"
                               TextWrapping="Wrap"
                               FontSize="13" />
                </Border>

                <!-- Action buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="{local:Localize Button_Cancel}"
                               Appearance="Secondary"
                               Command="{Binding CloseEditRecordDialogCommand}"
                               HorizontalAlignment="Stretch"
                               Height="40"
                               Padding="16,0" />

                    <ui:Button Grid.Column="2"
                               Content="{local:Localize Button_Save}"
                               Appearance="Primary"
                               Command="{Binding SaveEditRecordCommand}"
                               IsEnabled="{Binding EditRecordModel.CanSave}"
                               HorizontalAlignment="Stretch"
                               Height="40"
                               Padding="16,0" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Delete Record Confirmation Dialog Template -->
        <DataTemplate x:Key="DeleteRecordDialogTemplate">
            <StackPanel Width="420">
                <ui:SymbolIcon Symbol="Warning24"
                               FontSize="48"
                               Foreground="#F59E0B"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />

                <TextBlock Text="{local:Localize Dialog_DeleteRecord_Title}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock Text="{local:Localize Dialog_DeleteRecord_Message}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,20" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="{local:Localize Button_CancelDelete}"
                               Appearance="Secondary"
                               Tag="Cancel"
                               HorizontalAlignment="Stretch"
                               Height="40"
                               Padding="16,0" />

                    <ui:Button Grid.Column="2"
                               Content="{local:Localize Button_Delete}"
                               Appearance="Danger"
                               Tag="Delete"
                               HorizontalAlignment="Stretch"
                               Height="40"
                               Padding="16,0" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <!-- Main Content -->
    <Grid Margin="42,12,22,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,0,20,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                            PlaceholderText="{local:Localize Filter_SearchByActivityOrNotes}"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Height="34"
                            VerticalContentAlignment="Center"
                            Margin="0,0,0,0">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:TextBox.Icon>
            </ui:TextBox>

            <ComboBox Grid.Column="1"
                      IsEditable="False"
                      Width="200"
                      Height="33"
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding Activities}"
                      SelectedItem="{Binding SelectedActivityFilter}"
                      Margin="12,0,0,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="12"
                                     Height="12"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Fill="{Binding Color, Converter={StaticResource StringToBrushConverter}}" />
                            <TextBlock Text="{Binding Name}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                        <Setter Property="Tag" Value="{local:Localize Filter_AllActivities}" />
                    </Style>
                </ComboBox.Style>
            </ComboBox>

            <DatePicker Grid.Column="2"
                        Width="130"
                        Height="35"
                        Padding="12"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="12,0,0,0"
                        SelectedDateFormat="Short"
                        SelectedDate="{Binding SelectedDate}" />

            <!-- Sort Direction Toggle -->
            <ToggleButton Grid.Column="3"
                          IsChecked="{Binding SortAscending}"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0"
                          Height="36"
                          Width="40"
                          ToolTip="{local:Localize Filter_Sort_Tooltip}">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorSecondaryBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SystemFillColorSecondaryBackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ToggleButton.Style>
                <StackPanel Orientation="Horizontal">
                    <!-- Icon changes based on state -->
                    <ui:SymbolIcon Margin="0,0,0,0">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <!-- Default: descending (arrow down) -->
                                <Setter Property="Symbol" Value="ArrowDown24" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortAscending}" Value="True">
                                        <!-- Ascending: arrow up -->
                                        <Setter Property="Symbol" Value="ArrowUp24" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>
                   
                </StackPanel>
            </ToggleButton>

            <ui:Button Grid.Column="4"
                       Appearance="Primary"
                       Command="{Binding OpenNewRecordDialogCommand}"
                       Height="33"
                       Margin="48,0,0,0"
                       Padding="16,0"
                       HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" />
                    <TextBlock Text="{local:Localize Button_NewRecord}" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Records List -->
        <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" >
             
            <ItemsControl ItemsSource="{Binding GroupedRecords}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,20,24">
                            <!-- Day Header (separador amb label de data) -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                               Text="{Binding DateDisplay}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1"
                                               Text="{Binding TimeAgo}"
                                               FontSize="13"
                                               FontStyle="Italic"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Grid.Column="2"
                                               Text="{Binding TotalWorked}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Grid>

                            <!-- Timeline bar for this day -->
                            <controls:WorkdayTimelineBar
                                Margin="0,0,0,12"
                                BarHeight="20"
                                CornerRadius="4"
                                WorkdayStart="{Binding WorkdayStart}"
                                WorkdayEnd="{Binding WorkdayEnd}"
                                Segments="{Binding TimelineSegments}" />

                            <!-- Records for this day -->
                            <ItemsControl ItemsSource="{Binding Records}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CardAction Command="{Binding DataContext.OpenEditRecordDialogCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       behaviors:ScrollParentBehavior.BubbleScroll="True"
                                                       Margin="0,0,0,4"
                                                       Padding="16,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Activity Color Indicator -->
                                                <Ellipse Grid.Column="0"
                                                             Width="12"
                                                             Height="12"
                                                             Margin="0,0,16,0"
                                                             VerticalAlignment="Center"
                                                             Fill="{Binding ActivityColor, Converter={StaticResource StringToBrushConverter}}" />

                                                <!-- Activity Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ActivityName}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="14" />
                                                    <TextBlock Text="{Binding Notes}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="400"
                                                                   Visibility="{Binding Notes, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                                                </StackPanel>

                                                <!-- Time Info -->
                                                <StackPanel Grid.Column="2"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Right"
                                                                Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Duration}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="14"
                                                                   HorizontalAlignment="Right" />
                                                    <TextBlock FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   HorizontalAlignment="Right">
                                                            <Run Text="{Binding StartTime}" />
                                                            <Run Text=" - " />
                                                            <Run Text="{Binding EndTime}" />
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Three-dot menu button -->
                                                <ui:Button Grid.Column="3"
                                                           x:Name="RecordMenuButton"
                                                           Appearance="Transparent"
                                                           Padding="4"
                                                           VerticalAlignment="Center"
                                                           Click="RecordMenuButton_Click"
                                                           Tag="{Binding}">
                                                    <ui:SymbolIcon Symbol="MoreVertical24" FontSize="16" />
                                                    <ui:Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{local:Localize Menu_Edit}"
                                                                      Command="{Binding DataContext.OpenEditRecordDialogCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="Edit24" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{local:Localize Menu_Delete}"
                                                                      Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="16" Foreground="#EF4444" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </ui:Button.ContextMenu>
                                                </ui:Button>
                                            </Grid>
                                        </ui:CardAction>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding GroupedRecords.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
            <ui:SymbolIcon Symbol="Document24"
                               FontSize="48"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />
            <TextBlock Text="{local:Localize Empty_NoRecords}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4" />
            <TextBlock Text="{local:Localize Empty_CreateFirstRecord}"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
