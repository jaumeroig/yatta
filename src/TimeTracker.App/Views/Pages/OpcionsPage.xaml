<Page x:Class="TimeTracker.App.Views.Pages.OpcionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    d:DataContext="{d:DesignInstance vm:OpcionsViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="Opcions"
    Loaded="Page_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <StackPanel VerticalAlignment="Top" MaxWidth="800">
                <!-- Header -->
                <TextBlock Text="Opcions"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,32" />

                <!-- Tema -->
                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="ColorBackground24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Tema de l'aplicació"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Selecciona el tema de la interfície d'usuari"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox Width="200"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />
                </ui:CardControl>

                <!-- Idioma -->
                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="LocalLanguage24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Idioma (requereix reiniciar)"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Selecciona l'idioma de l'aplicació. Això invalidarà l'idioma predeterminat del sistema."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox Width="200"
                              ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />
                </ui:CardControl>

                <!-- Notificacions -->
                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Alert24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Notificacions"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Mostra notificacions per recordar-te registrar les hores"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}"
                                     Command="{Binding ToggleNotificationsCommand}" />
                </ui:CardControl>

                <!-- Jornada laboral -->
                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Clock24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Durada de la jornada laboral"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Defineix la durada esperada de la teva jornada laboral diària"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBox Text="{Binding WorkdayHours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="60"
                                    Margin="0,0,4,0" />
                        <TextBlock Text="h"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                        <ui:TextBox Text="{Binding WorkdayMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="60"
                                    Margin="0,0,4,0" />
                        <TextBlock Text="m"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                        <ui:Button Content="Desar"
                                   Command="{Binding SaveWorkdayTimeCommand}"
                                   Appearance="Primary"
                                   Padding="16,6" />
                    </StackPanel>
                </ui:CardControl>

                <!-- Separador -->
                <Separator Margin="0,20,0,20" />

                <!-- Sobre l'aplicació -->
                <TextBlock Text="Sobre l'aplicació"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,12" />

                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Info24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="TimeTracker"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AppVersion}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <!--<TextBlock Text=".NET 10, WPF, SQLite"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />-->
                </ui:CardControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
