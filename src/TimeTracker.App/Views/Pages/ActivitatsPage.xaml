<Page x:Class="TimeTracker.App.Views.Pages.ActivitatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    d:DataContext="{d:DesignInstance vm:ActivitatsViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="Activitats">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Top">
            <TextBlock Text="Activitats"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock Text="Gestió d'activitats i projectes"
                       FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
