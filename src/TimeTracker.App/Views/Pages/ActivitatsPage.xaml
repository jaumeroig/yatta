<Page x:Class="TimeTracker.App.Views.Pages.ActivitatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    xmlns:converters="clr-namespace:TimeTracker.App.Converters"
    xmlns:local="clr-namespace:TimeTracker.App.Markup"
    d:DataContext="{d:DesignInstance vm:ActivitatsViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900"
    Title="Activitats"
    Loaded="Page_Loaded">

    <Grid Margin="42,12,42,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <ui:Button Appearance="Primary"
                       Command="{Binding NavigateToNewActivityCommand}"
                       Padding="16,10"
                       HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" />
                    <TextBlock Text="{local:Localize Button_NewActivity}" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Activities List (Windows Settings Style) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding Activities.Count, Converter={StaticResource InverseCountToVisibilityConverter}, FallbackValue=Visible}">
            <ItemsControl ItemsSource="{Binding Activities}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardAction Command="{Binding DataContext.NavigateToActivityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}"
                                       Margin="0,0,0,4"
                                       Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Activity Icon -->
                                <Border Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        CornerRadius="8"
                                        Margin="0,0,16,0"
                                        Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}">
                                    <ui:SymbolIcon Symbol="Grid24"
                                                   Foreground="White"
                                                   FontSize="18" />
                                </Border>

                                <!-- Activity Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Activities.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
            <ui:SymbolIcon Symbol="Grid24"
                           FontSize="48"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,16" />
            <TextBlock Text="{local:Localize Empty_NoActivities}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock Text="{local:Localize Empty_CreateFirstActivity}"
                       FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
