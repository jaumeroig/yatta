<Page x:Class="TimeTracker.App.Views.Pages.ActivitatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    xmlns:converters="clr-namespace:TimeTracker.App.Converters"
    d:DataContext="{d:DesignInstance vm:ActivitatsViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900"
    Title="Activitats"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <DataTemplate x:Key="ActivityDialogTemplate">
            <StackPanel Width="480">
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="{Binding IsEditing, Converter={StaticResource ActivityEditingToTitleConverter}, FallbackValue='Nova activitat'}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <ui:Button HorizontalAlignment="Right"
                               Appearance="Transparent"
                               Command="{Binding CloseDialogCommand}"
                               Padding="4">
                        <ui:SymbolIcon Symbol="Dismiss24" />
                    </ui:Button>
                </Grid>

                <TextBlock Text="Nom de l'activitat"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ui:TextBox Text="{Binding EditingActivity.Name, Mode=TwoWay}"
                            PlaceholderText="Nom de l'activitat..."
                            Margin="0,0,0,16" />

                <TextBlock Text="Color"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <ItemsControl Margin="0,0,0,20">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Items>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#0078D4"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#0078D4" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#0078D4" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#10B981"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#10B981" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#10B981" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#F59E0B"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#F59E0B" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#F59E0B" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#EF4444"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#EF4444" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#EF4444" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#8B5CF6"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#8B5CF6" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#8B5CF6" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#EC4899"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#EC4899" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#EC4899" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#06B6D4"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#06B6D4" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#06B6D4" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#F97316"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#F97316" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="EditingActivity.Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#F97316" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                    </ItemsControl.Items>
                </ItemsControl>

                <CheckBox Content="Activitat activa"
                          IsChecked="{Binding EditingActivity.Active}"
                          Margin="0,0,0,20" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="{Binding IsEditing, Converter={StaticResource ActivityEditingToButtonTextConverter}, FallbackValue='Crear activitat'}"
                               Appearance="Primary"
                               Command="{Binding SaveActivityCommand}"
                               Padding="16,12"
                               HorizontalAlignment="Stretch" />

                    <ui:Button Grid.Column="2"
                               Content="Cancelar"
                               Appearance="Secondary"
                               Command="{Binding CloseDialogCommand}"
                               Padding="16,12"
                               HorizontalAlignment="Stretch" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DeleteActivityDialogTemplate">
            <StackPanel Width="420">
                <ui:SymbolIcon Symbol="Warning24"
                               FontSize="48"
                               Foreground="#F59E0B"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />

                <TextBlock Text="Eliminar activitat?"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,20">
                    <Run Text="Aquesta activitat té " />
                    <Run Text="{Binding ActivityToDelete.RecordCount}" FontWeight="SemiBold" />
                    <Run Text=" registres associats. Si l'elimines, es perdran totes les dades." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="Cancel·lar"
                               Appearance="Secondary"
                               Command="{Binding CancelDeleteCommand}"
                               HorizontalAlignment="Stretch"
                               Padding="16,10" />

                    <ui:Button Grid.Column="2"
                               Content="Eliminar"
                               Appearance="Danger"
                               Command="{Binding ConfirmDeleteActivityCommand}"
                               HorizontalAlignment="Stretch"
                               Padding="16,10" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- Main Content -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Activitats"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Gestiona les teves activitats i tasques"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <ui:Button Grid.Column="1"
                           Appearance="Primary"
                           Command="{Binding OpenNewActivityDialogCommand}"
                           Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" />
                        <TextBlock Text="Nova activitat" />
                    </StackPanel>
                </ui:Button>
            </Grid>

            <!-- Activities Grid -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Activities}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Width="280"
                                     Margin="0,0,16,16"
                                     Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Header with icon and menu -->
                                    <Grid Grid.Row="0" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Activity Icon -->
                                        <Border Grid.Column="0"
                                                Width="40"
                                                Height="40"
                                                CornerRadius="8"
                                                Margin="0,0,12,0"
                                                Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}">
                                            <ui:SymbolIcon Symbol="Grid24"
                                                           Foreground="White"
                                                           FontSize="20" />
                                        </Border>

                                        <!-- Activity Name -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />

                                        <!-- Actions Menu -->
                                        <ui:DropDownButton Grid.Column="2"
                                                           VerticalAlignment="Top"
                                                           Padding="8,4"
                                                           Appearance="Secondary">
                                            <ui:SymbolIcon Symbol="MoreHorizontal24" />
                                            <ui:DropDownButton.Flyout>
                                                <ContextMenu>
                                                    <ui:MenuItem Header="Editar"
                                                                 Command="{Binding DataContext.OpenEditActivityDialogCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 CommandParameter="{Binding}">
                                                        <ui:MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Edit24" />
                                                        </ui:MenuItem.Icon>
                                                    </ui:MenuItem>
                                                    <ui:MenuItem Header="Eliminar"
                                                                 Command="{Binding DataContext.RequestDeleteActivityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 CommandParameter="{Binding}">
                                                        <ui:MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Delete24" />
                                                        </ui:MenuItem.Icon>
                                                    </ui:MenuItem>
                                                </ContextMenu>
                                            </ui:DropDownButton.Flyout>
                                        </ui:DropDownButton>
                                    </Grid>

                                    <!-- Stats Section -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding RecordCount, StringFormat='{}{0} entrades'}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,4" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Temps total"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TotalTime}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Row="2"
                                            Background="{Binding Active, Converter={StaticResource ActivityStatusToBackgroundConverter}, FallbackValue=#E0E0E0}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Active, Converter={StaticResource ActivityStatusToForegroundConverter}, FallbackValue=#505050}" />
                                    </Border>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding Activities.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
                <ui:SymbolIcon Symbol="Grid24"
                               FontSize="48"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />
                <TextBlock Text="No hi ha activitats"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock Text="Crea la teva primera activitat"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
