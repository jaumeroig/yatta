<Page x:Class="TimeTracker.App.Views.Pages.ActivityDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    xmlns:converters="clr-namespace:TimeTracker.App.Converters"
    xmlns:local="clr-namespace:TimeTracker.App.Markup"
    d:DataContext="{d:DesignInstance vm:ActivityDetailViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="900"
    Title="Detall d'activitat"
    FocusManager.FocusedElement="{Binding ElementName=ActivityName}"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="White"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DeleteActivityDialogTemplate">
            <StackPanel Width="420">
                <ui:SymbolIcon Symbol="Warning24"
                               FontSize="48"
                               Foreground="#F59E0B"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />

                <TextBlock Text="{local:Localize Dialog_DeleteActivity_Title}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,20">
                    <Run Text="Aquesta activitat té " />
                    <Run Text="{Binding RecordCount}" FontWeight="SemiBold" />
                    <Run Text=" registres associats. Si l'elimines, es perdran totes les dades." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="{local:Localize Button_CancelDelete}"
                               Appearance="Secondary"
                               Command="{Binding CancelDeleteCommand}"
                               HorizontalAlignment="Stretch"
                               Padding="16,10" />

                    <ui:Button Grid.Column="2"
                               Content="{local:Localize Button_Delete}"
                               Appearance="Danger"
                               Command="{Binding ConfirmDeleteCommand}"
                               HorizontalAlignment="Stretch"
                               Padding="16,10" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="42,12,42,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Contingut principal -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                
                <!-- Nom de l'activitat -->
                <TextBlock Text="{local:Localize Label_ActivityName}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />
                <ui:TextBox x:Name="ActivityName" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{local:Localize Placeholder_ActivityName}"
                            Margin="0,0,0,4" />
                <TextBlock Text="{Binding NameError}"
                           Foreground="#EF4444"
                           FontSize="12"
                           Margin="0,0,0,20"
                           Visibility="{Binding HasNameError, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Color -->
                <TextBlock Text="{local:Localize Label_Color}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,12" />
                <ItemsControl Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Items>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#0078D4"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#0078D4" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#0078D4" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#10B981"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#10B981" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#10B981" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#F59E0B"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#F59E0B" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#F59E0B" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#EF4444"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#EF4444" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#EF4444" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#8B5CF6"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#8B5CF6" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#8B5CF6" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#EC4899"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#EC4899" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#EC4899" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#06B6D4"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#06B6D4" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#06B6D4" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                        <Button Width="40" Height="40" Margin="0,0,8,8"
                                Command="{Binding SelectColorCommand}"
                                CommandParameter="#F97316"
                                Style="{StaticResource ColorButtonStyle}">
                            <Button.Background>
                                <SolidColorBrush Color="#F97316" />
                            </Button.Background>
                            <Button.BorderThickness>
                                <Binding Path="Color">
                                    <Binding.Converter>
                                        <converters:SelectedColorToBorderThicknessConverter TargetColor="#F97316" />
                                    </Binding.Converter>
                                </Binding>
                            </Button.BorderThickness>
                        </Button>
                    </ItemsControl.Items>
                </ItemsControl>

                <!-- Estat actiu -->
                <CheckBox Content="{local:Localize CheckBox_ActivityActive}"
                          IsChecked="{Binding Active}"
                          Margin="0,0,0,24" />

                <!-- Estadístiques (només per activitats existents) -->
                <ui:Card Margin="0,0,0,24"
                         Padding="16"
                         Visibility="{Binding RecordCount, Converter={StaticResource PositiveCountToVisibilityConverter}, FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="{local:Localize ActivityDetail_Statistics}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{local:Localize ActivityDetail_RecordCount}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding RecordCount}"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{local:Localize Label_TotalTime}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding TotalTime}"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Botons d'acció -->
        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Botó eliminar (només per activitats existents) -->
            <ui:Button Grid.Column="0"
                       Appearance="Danger"
                       Command="{Binding RequestDeleteCommand}"
                       Padding="16,10"
                       Visibility="{Binding IsExistingActivity, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Delete24" Margin="0,0,8,0" />
                    <TextBlock Text="{local:Localize Button_Delete}" />
                </StackPanel>
            </ui:Button>

            <ui:Button Grid.Column="2"
                       Content="{local:Localize Button_Cancel}"
                       Appearance="Secondary"
                       Command="{Binding CancelCommand}"
                       Padding="16,10"
                       MinWidth="120" />

            <ui:Button Grid.Column="4"
                       Content="{local:Localize Button_Save}"
                       Appearance="Primary"
                       Command="{Binding SaveCommand}"
                       Padding="16,10"
                       MinWidth="120" />
        </Grid>
    </Grid>
</Page>
