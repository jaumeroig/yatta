<Page x:Class="TimeTracker.App.Views.Pages.WhatsNewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:md="http://schemas.lepo.co/wpfui/2022/xaml/markdown"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
    xmlns:local="clr-namespace:TimeTracker.App.Markup"
    xmlns:behaviors="clr-namespace:TimeTracker.App.Behaviors"
    d:DataContext="{d:DesignInstance vm:WhatsNewViewModel}"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="{local:Localize Page_WhatsNew_Title}"
    ScrollViewer.CanContentScroll="False"
    Loaded="Page_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,12,42,12">
            <md:MarkdownViewer 
                Markdown="{Binding MarkdownContent}"
                behaviors:ScrollParentBehavior.BubbleScroll="True" />
        </Grid>
    </ScrollViewer>
</Page>
