<UserControl x:Class="TimeTracker.App.Controls.TimePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             d:DesignHeight="40"
             d:DesignWidth="200"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ComboBox x:Name="HourComboBox"
                  Grid.Column="0"
                  IsEditable="True"
                  ItemsSource="{Binding Hours, ElementName=Root}"
                  Height="40" />
        <TextBlock Grid.Column="1"
                   Text=":"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="6,0"
                   FontSize="16"
                   FontWeight="SemiBold" />
        <ComboBox x:Name="MinuteComboBox"
                  Grid.Column="2"
                  IsEditable="True"
                  ItemsSource="{Binding Minutes, ElementName=Root}"
                  Height="40" />
    </Grid>
</UserControl>
