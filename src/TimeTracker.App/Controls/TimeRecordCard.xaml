<UserControl x:Class="TimeTracker.App.Controls.TimeRecordCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:TimeTracker.App.Markup"
             x:Name="Root"
             d:DesignHeight="96"
             d:DesignWidth="760"
             mc:Ignorable="d">
    <Border x:Name="ActiveBorder"
            BorderThickness="2"
            CornerRadius="8"
            Padding="0">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, ElementName=Root}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <ui:CardAction Command="{Binding CardClickCommand, ElementName=Root}"
                       CommandParameter="{Binding CommandParameter, ElementName=Root}"
                       IsChevronVisible="False"
                       Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="4"
                        CornerRadius="2,0,0,2"
                        Background="{Binding ActivityColor, ElementName=Root, Converter={StaticResource StringToBrushConverter}}" />

                <Grid Grid.Column="1" Margin="12,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon Grid.Column="0"
                                   x:Name="LocationIcon"
                                   Symbol="Building24"
                                   VerticalAlignment="Center"
                                   Margin="0,1,10,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   ToolTip="{local:Localize Location_Office}" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActivityName, ElementName=Root}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock x:Name="NotesTextBlock"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Notes, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}" />

                        <ui:Button x:Name="ToggleNotesButton"
                                   Appearance="Transparent"
                                   Padding="2"
                                   Margin="0,2,0,0"
                                   Width="24"
                                   Height="24"
                                   BorderThickness="0"
                                   HorizontalAlignment="Left"
                                   Click="ToggleNotesButton_Click"
                                   Visibility="Collapsed">
                            <ui:SymbolIcon x:Name="ToggleNotesIcon" Symbol="ChevronDown24" FontSize="14" />
                        </ui:Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="0,0,18,0">
                        <TextBlock Text="{Binding Duration, ElementName=Root}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   HorizontalAlignment="Right" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding StartTime, ElementName=Root}" />
                            <Run Text=" - " />
                            <Run Text="{Binding EndTime, ElementName=Root}" />
                        </TextBlock>
                    </StackPanel>

                    <ui:Button Grid.Column="3"
                               x:Name="RecordMenuButton"
                               Appearance="Transparent"
                               Padding="4"
                               BorderThickness="0"
                               VerticalAlignment="Center"
                               Click="RecordMenuButton_Click"
                               Visibility="{Binding IsActive, ElementName=Root, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="MoreVertical24" FontSize="16" />
                        <ui:Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{local:Localize Menu_Edit}" Click="EditMenuItem_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Edit24" FontSize="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{local:Localize Menu_Delete}" Click="DeleteMenuItem_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Delete24"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>
                </Grid>
            </Grid>
        </ui:CardAction>
    </Border>
</UserControl>
